# ─────────────────────────────────────────────────────────────
# EnrollMate environment variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`. No secret below may reach the browser.
# ─────────────────────────────────────────────────────────────

# Supabase (public — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role (server-only — bypasses RLS, never expose)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini — used for the user-facing chat LLM (server-only)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash

# OpenAI — used for embeddings (RAG) and Whisper voice transcription (server-only)
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TRANSCRIBE_MODEL=whisper-1

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Rate limiting (public chat protection)
CHAT_RATE_LIMIT_PER_MINUTE=15
CHAT_MAX_MESSAGES_PER_SESSION=50

# ─────────────────────────────────────────────────────────────
# Phase 2 — Auth
# ─────────────────────────────────────────────────────────────

# Canonical public URL of this deployment — used in magic-link emails and OAuth callbacks.
# Set to your Vercel URL in production (e.g. https://course-advisor-ai-ochre.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public self-service signup. Keep true for school/demo SaaS trial flow; set false for managed-pilot-only deployments.
NEXT_PUBLIC_SELF_SERVICE_SIGNUP_ENABLED=true

# Optional Cloudflare Turnstile public site key for login/register protection.
# Enable the matching Turnstile secret in Supabase Auth CAPTCHA settings.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional: protect the /o/[slug]/usage page in production.
USAGE_DASHBOARD_TOKEN=

# ─────────────────────────────────────────────────────────────
# Phase 3 — Billing (Stripe)
# ─────────────────────────────────────────────────────────────

# Stripe secret key (server-only — never expose)
STRIPE_SECRET_KEY=sk_test_...

# Stripe webhook secret — from `stripe listen` locally or Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe publishable key (safe for the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe price IDs — create recurring monthly prices in your Stripe dashboard
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# ─────────────────────────────────────────────────────────────
# Phase 3 — Email (Resend)
# ─────────────────────────────────────────────────────────────

# Resend API key — https://resend.com
RESEND_API_KEY=re_...

# Sender address — must be a verified domain in Resend
EMAIL_FROM=noreply@enrollmate.ai

# Concierge integrations. Use long random values; both are server-only.
INTEGRATION_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
CRON_SECRET=replace-with-a-long-random-cron-secret

# Optional managed-pilot sales/booking URL.
SALES_CONTACT_URL=https://calendly.com/your-team/discovery
