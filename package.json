{
  "name": "enrollmate",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "Steff <steffpouassi@gmail.com>",
  "description": "EnrollMate enrolment concierge with RAG, admissions workflow, analytics, and lead capture.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "ingest": "tsx --env-file=.env.local --conditions=react-server scripts/ingest-courses.ts",
    "seed:demo": "tsx --env-file=.env.local --conditions=react-server scripts/seed-demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@google/generative-ai": "^0.21.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "geist": "^1.3.1",
    "lucide-react": "^0.460.0",
    "next": "^16.2.2",
    "openai": "^4.67.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.14.0",
    "server-only": "0.0.1",
    "stripe": "^22.2.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.6"
  }
}
